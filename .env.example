# Server Configuration
PORT=3000
NODE_ENV=development

# Security
JWT_SECRET=your_super_secret_jwt_key_here
API_KEY=your_api_key_here

# Database (if using MongoDB)
MONGODB_URI=mongodb://localhost:27017/shadowbooster

# TikTok Service Provider API (if using third-party service)
TIKTOK_API_URL=https://api.tiktokservice.com
TIKTOK_API_KEY=your_tiktok_service_api_key

# Payment Gateway (if accepting payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_secret

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
